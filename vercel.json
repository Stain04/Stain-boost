{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/how-to-climb-faster",       "destination": "/blog/how-to-climb-faster" },
    { "source": "/elo-boosting-safe",          "destination": "/blog/elo-boosting-safe" },
    { "source": "/best-champions-solo-queue",  "destination": "/blog/best-champions-solo-queue" },
    { "source": "/what-is-elo-boosting",       "destination": "/blog/what-is-elo-boosting" },
    { "source": "/how-to-escape-silver",       "destination": "/blog/how-to-escape-silver" },
    { "source": "/master-yi-build-guide",      "destination": "/blog/master-yi-build-guide" },
    { "source": "/how-to-reach-diamond",        "destination": "/blog/how-to-reach-diamond" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",            "value": "DENY" },
        { "key": "X-XSS-Protection",           "value": "1; mode=block" },
        { "key": "Referrer-Policy",            "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",         "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security",  "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy",    "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com; frame-ancestors 'none';" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Robots-Tag",           "value": "noindex" },
        { "key": "Cache-Control",          "value": "no-store" }
      ]
    }
  ]
}